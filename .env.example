# ===========================
# ENVIRONMENT VARIABLES TEMPLATE
# ===========================
# Copy file ini menjadi .env dan isi sesuai konfigurasi lokal Anda

# ==== BACKEND CONFIGURATION ====

## Node Environment
NODE_ENV=development

## Server Port
PORT=5000

## Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=spk_sapi_qurban
DB_DIALECT=mysql

## JWT Secret Key
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production

## Admin WhatsApp Contact
ADMIN_WA_NUMBER=6281234567890

## File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ==== FRONTEND CONFIGURATION ====

## API Base URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ===========================
# NOTES:
# ===========================
# 1. Jangan commit .env ke repository
# 2. .env.local di frontend tidak perlu di-commit
# 3. Untuk production, gunakan .env.production dengan nilai yang aman
# 4. Pastikan JWT_SECRET di-generate dengan random yang kuat
# 5. Database PASS kosong hanya untuk lokal development
